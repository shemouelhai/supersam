<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SUPERSAM V4 — L'Infiniam Fractal Engine</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
/* ═══════════════════════════════════════════════════════════════════
   SUPERSAM V4 — FEUILLE DE STYLE COSMIQUE
   Thème : Cyberpunk Celtique / Bioluminescent / Tribal Cosmique
═══════════════════════════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Exo+2:ital,wght@0,100;0,400;0,700;1,200&display=swap');

:root {
–void: #00000d;
–deep: #010a1a;
–plasma: #020f2a;
–hot: #ff3d00;
–solar: #ffaa00;
–cold: #00d4ff;
–crystal: #7df9ff;
–life: #39ff14;
–violet: #9d00ff;
–rose: #ff006e;
–berg: #ffd700;
–foam: #00ff9f;
–slate: rgba(0,212,255,0.06);
–border: rgba(0,212,255,0.18);
–border-hot: rgba(255,61,0,0.35);
–text-dim: rgba(0,212,255,0.45);
–glow-hot: 0 0 15px #ff3d0066, 0 0 40px #ff3d0022;
–glow-cold: 0 0 15px #00d4ff66, 0 0 40px #00d4ff22;
–glow-life: 0 0 12px #39ff1455, 0 0 30px #39ff1415;
–glow-berg: 0 0 12px #ffd70055, 0 0 30px #ffd70015;
–panel-bg: rgba(1,10,26,0.88);
}

- { margin:0; padding:0; box-sizing:border-box; }
  html, body { width:100%; height:100%; overflow:hidden; }

body {
background: var(–void);
color: var(–cold);
font-family: ‘Share Tech Mono’, monospace;
font-size: 11px;
}

/* ── SCROLLBARS ── */
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0,212,255,0.3); border-radius:2px; }

/* ── CANVAS ── */
#canvas3d {
position:fixed; top:0; left:0;
width:100%; height:100%;
z-index:0;
}

/* ── GRAIN OVERLAY ── */
#grain {
position:fixed; top:0; left:0;
width:100%; height:100%;
z-index:1;
opacity:0.025;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’/%3E%3C/svg%3E”);
pointer-events:none;
}

/* ── UI SHELL ── */
#ui {
position:fixed; top:0; left:0;
width:100%; height:100%;
z-index:10;
display:grid;
grid-template-columns: 270px 1fr 270px;
grid-template-rows: 56px 1fr 160px;
pointer-events:none;
}

/* ══ HEADER ══ */
#hdr {
grid-column: 1/-1; grid-row: 1;
display:flex; align-items:center; justify-content:space-between;
padding: 0 18px;
background: linear-gradient(90deg, rgba(0,0,13,0.98) 0%, rgba(1,10,26,0.95) 50%, rgba(0,0,13,0.98) 100%);
border-bottom: 1px solid var(–border);
pointer-events:all;
position:relative;
overflow:hidden;
}
#hdr::before {
content:’’;
position:absolute; bottom:0; left:0; right:0; height:1px;
background: linear-gradient(90deg, transparent, var(–cold), var(–hot), var(–solar), var(–cold), transparent);
opacity:0.6;
animation: scanline 4s linear infinite;
}
@keyframes scanline { from{background-position:-100% 0} to{background-position:200% 0} }

.logo-wrap { display:flex; align-items:center; gap:10px; }
.logo-icon {
width:34px; height:34px;
border:1px solid rgba(255,170,0,0.4);
border-radius:4px;
display:flex; align-items:center; justify-content:center;
font-family:‘Orbitron’, sans-serif;
font-size:10px; font-weight:900;
color:var(–solar);
box-shadow: var(–glow-hot);
animation: pulse-logo 3s ease-in-out infinite;
position:relative; overflow:hidden;
}
.logo-icon::after {
content:’’;
position:absolute; inset:0;
background: linear-gradient(135deg, transparent 40%, rgba(255,170,0,0.1) 100%);
}
@keyframes pulse-logo {
0%,100%{ box-shadow: var(–glow-hot); }
50%{ box-shadow: 0 0 25px #ffaa0088, 0 0 60px #ffaa0033; }
}
.logo-text {
font-family:‘Orbitron’, sans-serif;
font-weight:900; font-size:1rem; letter-spacing:5px;
background: linear-gradient(90deg, var(–hot) 0%, var(–solar) 40%, var(–cold) 100%);
-webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.logo-sub {
font-family:‘Exo 2’, sans-serif;
font-size:0.55rem; letter-spacing:3px;
color: var(–text-dim);
font-style:italic;
}

.hdr-center {
display:flex; gap:20px; align-items:center;
}
.hdr-stat {
text-align:center;
}
.hdr-stat-val {
font-family:‘Orbitron’, sans-serif;
font-size:1rem; font-weight:700;
line-height:1;
}
.hdr-stat-lbl { font-size:0.55rem; color:var(–text-dim); letter-spacing:2px; }

.berg-display {
display:flex; align-items:center; gap:8px;
background: rgba(255,215,0,0.06);
border:1px solid rgba(255,215,0,0.2);
border-radius:4px;
padding:5px 12px;
box-shadow: var(–glow-berg);
}
.berg-display .val {
font-family:‘Orbitron’, sans-serif;
font-weight:700; font-size:1rem;
color:var(–berg);
}
.berg-display .lbl { font-size:0.55rem; color:rgba(255,215,0,0.5); letter-spacing:2px; }

/* ══ PANELS ══ */
#p-left {
grid-column:1; grid-row:2;
padding:10px 10px 10px 12px;
display:flex; flex-direction:column; gap:8px;
pointer-events:all;
overflow-y:auto;
}
#p-right {
grid-column:3; grid-row:2;
padding:10px 12px 10px 10px;
display:flex; flex-direction:column; gap:8px;
pointer-events:all;
overflow-y:auto;
}
#p-bottom {
grid-column:1/-1; grid-row:3;
display:flex; gap:8px; padding:8px 12px;
align-items:stretch;
background: linear-gradient(0deg, rgba(0,0,13,0.95) 0%, transparent 100%);
border-top: 1px solid var(–border);
pointer-events:all;
}

/* ══ MODULES ══ */
.mod {
background: var(–panel-bg);
border:1px solid var(–border);
border-radius:3px;
padding:9px 10px;
backdrop-filter: blur(12px);
flex-shrink:0;
position:relative;
overflow:hidden;
}
.mod::before {
content:’’;
position:absolute; top:0; left:0; right:0; height:1px;
background: linear-gradient(90deg, transparent, var(–cold), transparent);
opacity:0.3;
}
.mod.hot-mod { border-color: var(–border-hot); }
.mod.hot-mod::before { background: linear-gradient(90deg, transparent, var(–hot), transparent); }
.mod.life-mod { border-color: rgba(57,255,20,0.2); }
.mod.life-mod::before { background: linear-gradient(90deg, transparent, var(–life), transparent); }
.mod.berg-mod { border-color: rgba(255,215,0,0.2); }
.mod.berg-mod::before { background: linear-gradient(90deg, transparent, var(–berg), transparent); }

.mod-title {
font-family:‘Orbitron’, sans-serif;
font-size:0.58rem; letter-spacing:3px;
color:var(–text-dim); text-transform:uppercase;
margin-bottom:8px; padding-bottom:5px;
border-bottom:1px solid rgba(0,212,255,0.08);
display:flex; align-items:center; justify-content:space-between;
}
.mod-badge {
font-size:0.5rem; letter-spacing:1px; padding:1px 5px;
border-radius:2px; font-family:‘Share Tech Mono’, monospace;
}
.badge-actif { background:rgba(57,255,20,0.15); color:var(–life); border:1px solid rgba(57,255,20,0.3); }
.badge-hot { background:rgba(255,61,0,0.15); color:var(–hot); border:1px solid rgba(255,61,0,0.3); }
.badge-cold { background:rgba(0,212,255,0.1); color:var(–cold); border:1px solid rgba(0,212,255,0.25); }

/* ── JAUGES ── */
.gauge-row {
display:flex; align-items:center; gap:6px;
margin-bottom:5px;
}
.g-lbl { color:var(–text-dim); width:52px; flex-shrink:0; letter-spacing:1px; font-size:0.6rem; }
.g-bar {
flex:1; height:5px;
background:rgba(0,212,255,0.08);
border-radius:3px; overflow:hidden;
position:relative;
}
.g-fill {
height:100%; border-radius:3px;
transition: width 0.4s cubic-bezier(0.4,0,0.2,1);
position:relative;
}
.g-fill.cold { background: linear-gradient(90deg, #004466, var(–cold)); }
.g-fill.hot  { background: linear-gradient(90deg, #661100, var(–hot)); }
.g-fill.life { background: linear-gradient(90deg, #003311, var(–life)); }
.g-fill.berg { background: linear-gradient(90deg, #332200, var(–berg)); }
.g-fill.violet { background: linear-gradient(90deg, #220033, var(–violet)); }
.g-fill.foam { background: linear-gradient(90deg, #003322, var(–foam)); }
.g-fill::after {
content:’’; position:absolute;
right:0; top:0; width:3px; height:100%;
background:white; border-radius:1px;
box-shadow:0 0 5px white;
}
.g-val { color:var(–cold); width:34px; text-align:right; font-size:0.6rem; }

/* ── STAT GRILLE ── */
.stat-grid {
display:grid; grid-template-columns:1fr 1fr;
gap:5px;
}
.stat-cell {
background:rgba(0,212,255,0.04);
border:1px solid rgba(0,212,255,0.08);
border-radius:3px;
padding:5px 7px;
text-align:center;
}
.stat-cell .sv {
font-family:‘Orbitron’, sans-serif;
font-size:0.9rem; font-weight:700;
color:var(–cold); line-height:1;
}
.stat-cell .sl { font-size:0.5rem; color:var(–text-dim); letter-spacing:1px; }
.stat-cell.hot .sv { color:var(–hot); }
.stat-cell.life .sv { color:var(–life); }
.stat-cell.berg .sv { color:var(–berg); }
.stat-cell.violet .sv { color:var(–violet); }
.stat-cell.foam .sv { color:var(–foam); }

/* ── PATTERN LIST ── */
.pattern-item {
display:flex; align-items:center; gap:6px;
margin-bottom:4px; padding:3px 5px;
background:rgba(0,212,255,0.03);
border-left:2px solid rgba(0,212,255,0.2);
border-radius:0 2px 2px 0;
transition:all 0.3s;
}
.pattern-item:hover { background:rgba(0,212,255,0.07); }
.p-rank { color:var(–text-dim); width:14px; font-size:0.58rem; }
.p-name { flex:1; color:var(–cold); font-size:0.6rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.p-score {
font-size:0.58rem;
background:rgba(0,212,255,0.1);
color:var(–cold);
padding:1px 5px; border-radius:2px;
}

/* ── FLUX ÉMOTIONNEL ── */
.emo-grid {
display:grid; grid-template-columns:repeat(4,1fr); gap:4px;
}
.emo-cell {
padding:5px 4px; text-align:center;
background:rgba(0,0,0,0.4);
border:1px solid rgba(157,0,255,0.15);
border-radius:3px; cursor:pointer;
transition:all 0.2s;
}
.emo-cell:hover {
background:rgba(157,0,255,0.12);
border-color:rgba(157,0,255,0.4);
transform:translateY(-1px);
}
.emo-cell.active {
background:rgba(157,0,255,0.2);
border-color:var(–violet);
box-shadow:0 0 10px rgba(157,0,255,0.3);
}
.emo-icon { font-size:1rem; line-height:1; }
.emo-name { font-size:0.48rem; color:var(–text-dim); letter-spacing:1px; margin-top:2px; }
.emo-val { font-size:0.6rem; color:var(–violet); font-weight:700; }

/* ── CUBE FORMES ── */
.forms-grid {
display:grid; grid-template-columns:repeat(4,1fr); gap:4px;
}
.form-btn {
padding:6px 4px; text-align:center;
background:rgba(0,212,255,0.05);
border:1px solid var(–border);
border-radius:3px; cursor:pointer;
transition:all 0.2s;
font-size:0.75rem;
}
.form-btn:hover, .form-btn.active {
background:rgba(0,212,255,0.15);
border-color:var(–cold);
box-shadow:var(–glow-cold);
}
.form-name { font-size:0.48rem; color:var(–text-dim); letter-spacing:1px; }

/* ── TEXTURES ── */
.tex-grid { display:flex; flex-wrap:wrap; gap:4px; }
.tex-btn {
padding:3px 7px;
background:rgba(0,212,255,0.05);
border:1px solid var(–border);
border-radius:2px; cursor:pointer;
font-size:0.55rem; letter-spacing:1px;
color:var(–text-dim);
transition:all 0.2s;
}
.tex-btn:hover, .tex-btn.active {
background:rgba(255,170,0,0.1);
border-color:var(–solar);
color:var(–solar);
}

/* ── CYCLE A→Z ── */
.cycle-track {
display:flex; align-items:center; gap:3px;
overflow:hidden;
}
.cycle-node {
flex:1; height:20px;
display:flex; align-items:center; justify-content:center;
font-size:0.55rem; font-weight:700;
border-radius:2px;
background:rgba(0,212,255,0.05);
border:1px solid rgba(0,212,255,0.1);
transition:all 0.3s;
}
.cycle-node.active {
background:rgba(57,255,20,0.15);
border-color:var(–life);
color:var(–life);
box-shadow:var(–glow-life);
}
.cycle-node.done {
background:rgba(0,212,255,0.08);
border-color:rgba(0,212,255,0.3);
color:var(–cold);
}

/* ── FOAM VISUAL ── */
.foam-field {
height:40px;
background:rgba(0,255,159,0.04);
border:1px solid rgba(0,255,159,0.15);
border-radius:3px;
position:relative; overflow:hidden;
}
.foam-bubble {
position:absolute; border-radius:50%;
background:radial-gradient(circle, rgba(0,255,159,0.4), rgba(0,255,159,0.05));
border:1px solid rgba(0,255,159,0.3);
animation: foam-float 3s ease-in-out infinite;
}
@keyframes foam-float {
0%,100%{ transform:translateY(0) scale(1); opacity:0.6; }
50%{ transform:translateY(-4px) scale(1.1); opacity:1; }
}

/* ── TERMINAL INPUT ── */
.terminal-wrap {
flex:1; display:flex; flex-direction:column; gap:6px;
}
.terminal-output {
flex:1;
background:rgba(0,0,13,0.9);
border:1px solid var(–border);
border-radius:3px;
padding:8px;
overflow-y:auto;
font-size:0.62rem; line-height:1.7;
}
.t-line { margin-bottom:1px; }
.t-line.sys { color:var(–text-dim); }
.t-line.ok { color:var(–life); }
.t-line.warn { color:var(–solar); }
.t-line.hot { color:var(–hot); }
.t-line.berg { color:var(–berg); }
.t-line.foam { color:var(–foam); }
.terminal-input-row {
display:flex; gap:6px; align-items:center;
}
.t-prompt { color:var(–solar); font-size:0.65rem; flex-shrink:0; }
.t-input {
flex:1; background:rgba(0,0,13,0.8);
border:1px solid var(–border); border-radius:3px;
padding:5px 8px; color:var(–cold);
font-family:‘Share Tech Mono’, monospace; font-size:0.65rem;
outline:none; pointer-events:all;
}
.t-input:focus { border-color:var(–cold); box-shadow:var(–glow-cold); }
.t-btn {
padding:5px 12px; border:1px solid var(–border);
background:rgba(0,212,255,0.08); color:var(–cold);
font-family:‘Share Tech Mono’, monospace; font-size:0.6rem;
border-radius:3px; cursor:pointer; letter-spacing:1px;
transition:all 0.2s; pointer-events:all;
}
.t-btn:hover { background:rgba(0,212,255,0.2); box-shadow:var(–glow-cold); }
.t-btn.fire { border-color:var(–border-hot); color:var(–hot); background:rgba(255,61,0,0.08); }
.t-btn.fire:hover { background:rgba(255,61,0,0.18); box-shadow:var(–glow-hot); }

/* ── CUBE COUNT DISPLAY ── */
.cube-display {
display:flex; flex-direction:column; gap:5px;
}
.cube-row {
display:flex; align-items:center; gap:6px;
}
.cube-icon { font-size:1rem; }
.cube-info { flex:1; }
.cube-name { color:var(–cold); font-size:0.6rem; letter-spacing:1px; }
.cube-count {
font-family:‘Orbitron’, sans-serif;
font-weight:700; font-size:0.75rem;
color:var(–solar);
}
.cube-mini-bar {
height:3px; background:rgba(255,170,0,0.1);
border-radius:2px; overflow:hidden;
}
.cube-mini-fill {
height:100%;
background: linear-gradient(90deg, var(–hot), var(–solar));
border-radius:2px; transition:width 0.5s;
}

/* ── MULTI-BOUCLE ELEVATOR ── */
.elevator-vis {
display:flex; gap:3px; align-items:flex-end;
height:50px;
}
.el-col {
flex:1; background:rgba(0,212,255,0.05);
border:1px solid rgba(0,212,255,0.1);
border-radius:2px 2px 0 0;
display:flex; flex-direction:column; justify-content:flex-end;
position:relative; overflow:hidden;
transition:all 0.3s;
}
.el-fill {
background: linear-gradient(0deg, var(–violet), rgba(157,0,255,0.3));
transition:height 0.4s cubic-bezier(0.4,0,0.2,1);
}
.el-lbl {
position:absolute; bottom:2px; left:0; right:0;
text-align:center; font-size:0.45rem;
color:rgba(157,0,255,0.7);
}

/* ── BOUTONS D’ACTION ── */
.action-grid {
display:grid; grid-template-columns:1fr 1fr; gap:5px;
}
.act-btn {
padding:7px 5px; text-align:center;
background:rgba(0,212,255,0.05);
border:1px solid var(–border);
border-radius:3px; cursor:pointer;
transition:all 0.2s; font-size:0.58rem; letter-spacing:1px;
color:var(–cold);
}
.act-btn:hover { background:rgba(0,212,255,0.12); border-color:var(–cold); }
.act-btn.hot-btn { border-color:var(–border-hot); color:var(–hot); background:rgba(255,61,0,0.05); }
.act-btn.hot-btn:hover { background:rgba(255,61,0,0.15); }
.act-btn.life-btn { border-color:rgba(57,255,20,0.25); color:var(–life); background:rgba(57,255,20,0.04); }
.act-btn.life-btn:hover { background:rgba(57,255,20,0.12); }
.act-btn.berg-btn { border-color:rgba(255,215,0,0.25); color:var(–berg); background:rgba(255,215,0,0.04); }
.act-btn.berg-btn:hover { background:rgba(255,215,0,0.12); }

/* ── ANIMATIONS GLOBALES ── */
@keyframes blink { 0%,100%{ opacity:1; } 50%{ opacity:0.2; } }
.blink { animation:blink 1.5s ease-in-out infinite; }

@keyframes slide-in { from{ opacity:0; transform:translateX(-10px); } to{ opacity:1; transform:translateX(0); } }
.slide-in { animation:slide-in 0.3s ease-out forwards; }

.pulse-hot { animation:pulse-hot-kf 2s ease-in-out infinite; }
@keyframes pulse-hot-kf {
0%,100%{ text-shadow:0 0 6px var(–hot); }
50%{ text-shadow:0 0 20px var(–hot), 0 0 40px #ff3d0033; }
}

/* ── MÉDAILLON CENTRAL ── */
#center-hud {
grid-column:2; grid-row:2;
display:flex; flex-direction:column;
align-items:center; justify-content:flex-end;
padding-bottom:12px;
pointer-events:none;
}
.center-info {
display:flex; gap:20px; align-items:center;
background:rgba(1,10,26,0.7);
border:1px solid var(–border);
border-radius:4px;
padding:8px 20px;
backdrop-filter:blur(12px);
}
.ci-val {
font-family:‘Orbitron’, sans-serif;
font-size:1.4rem; font-weight:900;
text-align:center; line-height:1;
}
.ci-lbl { font-size:0.52rem; color:var(–text-dim); letter-spacing:2px; text-align:center; }
.ci-sep { width:1px; height:30px; background:var(–border); }

/* ── TOOLTIP CUBE ── */
#cube-tooltip {
position:fixed;
background:rgba(1,10,26,0.95);
border:1px solid var(–border);
border-radius:4px; padding:8px 12px;
font-size:0.6rem; color:var(–cold);
pointer-events:none; z-index:100;
display:none;
backdrop-filter:blur(12px);
max-width:180px;
}
#cube-tooltip .tt-name {
font-family:‘Orbitron’, sans-serif;
font-size:0.65rem; font-weight:700;
color:var(–solar); margin-bottom:4px;
}

/* ── NOTIFICATIONS ── */
#notif-stack {
position:fixed; top:70px; left:50%; transform:translateX(-50%);
z-index:200; display:flex; flex-direction:column; gap:4px;
pointer-events:none;
}
.notif {
background:rgba(1,10,26,0.95);
border:1px solid var(–border);
border-radius:3px; padding:5px 14px;
font-size:0.62rem; color:var(–cold);
text-align:center;
animation: notif-kf 3s ease-out forwards;
backdrop-filter:blur(10px);
}
@keyframes notif-kf {
0%{ opacity:0; transform:translateY(-8px); }
10%{ opacity:1; transform:translateY(0); }
80%{ opacity:1; }
100%{ opacity:0; transform:translateY(-4px); }
}
.notif.berg { border-color:rgba(255,215,0,0.4); color:var(–berg); }
.notif.hot { border-color:var(–border-hot); color:var(–hot); }
.notif.life { border-color:rgba(57,255,20,0.3); color:var(–life); }

/* ── SPLASHSCREEN ── */
#splash {
position:fixed; inset:0; z-index:9999;
background:var(–void);
display:flex; flex-direction:column;
align-items:center; justify-content:center; gap:20px;
transition:opacity 0.8s ease;
}
.splash-logo {
font-family:‘Orbitron’, sans-serif;
font-size:2.5rem; font-weight:900; letter-spacing:8px;
background: linear-gradient(135deg, var(–hot) 0%, var(–solar) 40%, var(–cold) 100%);
-webkit-background-clip:text; -webkit-text-fill-color:transparent;
animation:pulse-logo 2s ease-in-out infinite;
}
.splash-sub {
font-family:‘Exo 2’, sans-serif; font-style:italic;
font-size:0.75rem; letter-spacing:5px; color:var(–text-dim);
}
.splash-bar {
width:300px; height:3px;
background:rgba(0,212,255,0.1); border-radius:2px;
overflow:hidden;
}
.splash-fill {
height:100%;
background: linear-gradient(90deg, var(–hot), var(–solar), var(–cold));
border-radius:2px;
animation: load-kf 2.2s ease-in-out forwards;
}
@keyframes load-kf { from{width:0} to{width:100%} }
.splash-status {
font-size:0.6rem; color:var(–text-dim);
letter-spacing:2px; min-height:16px;
}

/* ── MOBILE TOUCH ── */
@media (max-width:768px) {
#ui {
grid-template-columns: 0 1fr 0;
grid-template-rows: 50px 1fr 180px;
}
#p-left, #p-right { display:none; }
#p-bottom {
flex-direction:column; padding:6px 8px; gap:6px;
}
.logo-sub { display:none; }
#center-hud { justify-content:center; align-items:center; }
}
</style>

</head>
<body>

